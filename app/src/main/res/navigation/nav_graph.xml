<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment2">

    <fragment
        android:id="@+id/loginFragment2"
        android:name="com.example.serviconnect.ui.auth.LoginFragment"
        android:label="fragment_login"
        tools:layout="@layout/fragment_login"
        >
        <action
            android:id="@+id/action_loginFragment2_to_registerFragment"
            app:destination="@id/registerFragment" />

        <action
            android:id="@+id/action_loginFragment2_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_loginFragment2_to_dashboardFragment"
            app:destination="@id/dashboardFragment" />
    </fragment>
    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.serviconnect.ui.auth.RegisterFragment"
        android:label="fragment_register"
        tools:layout="@layout/fragment_register" >
        <action
            android:id="@+id/action_registerFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_registerFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment" />
    </fragment>
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.serviconnect.ui.seeker.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_homeFragment_to_loginFragment2"
            app:destination="@id/loginFragment2" />
        <action
            android:id="@+id/action_homeFragment_to_providerListFragment"
            app:destination="@id/providerListFragment" />
    </fragment>
    <fragment
        android:id="@+id/baseFragment"
        android:name="com.example.serviconnect.ui.common.BaseFragment"
        android:label="fragment_base"
        tools:layout="@layout/fragment_base" />
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.serviconnect.ui.provider.DashboardFragment"
        android:label="fragment_dashboard"
        tools:layout="@layout/fragment_dashboard" />
    <fragment
        android:id="@+id/historyFragment"
        android:name="com.example.serviconnect.ui.provider.HistoryFragment"
        android:label="fragment_history"
        tools:layout="@layout/fragment_history" />
    <fragment
        android:id="@+id/providerDetailFragment"
        android:name="com.example.serviconnect.ui.seeker.ProviderDetailFragment"
        android:label="fragment_provider_detail"
        tools:layout="@layout/fragment_provider_detail" />
    <fragment
        android:id="@+id/providerListFragment"
        android:name="com.example.serviconnect.ui.seeker.ProviderListFragment"
        android:label="fragment_provider_list"
        tools:layout="@layout/fragment_provider_list" >
        <action
            android:id="@+id/action_providerListFragment_to_providerDetailFragment"
            app:destination="@id/providerDetailFragment" />
    </fragment>
    <fragment
        android:id="@+id/requestDetailFragment"
        android:name="com.example.serviconnect.ui.provider.RequestDetailFragment"
        android:label="fragment_request_detail"
        tools:layout="@layout/fragment_request_detail" />
</navigation>